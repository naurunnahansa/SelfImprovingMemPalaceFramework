# Neon Postgres connection string
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Gemini API key (for embeddings)
GOOGLE_API_KEY=your-google-api-key

# Exa API key (for fact verification web search)
EXA_API_KEY=your-exa-api-key

# LLM models — format: "provider:model-name"
# Supported providers: google, anthropic, openai
# Examples:
#   google:gemini-2.5-pro, google:gemini-2.0-flash
#   anthropic:claude-sonnet-4-20250514, anthropic:claude-haiku-4-5-20251001
#   openai:gpt-4o, openai:gpt-4o-mini
MAIN_MODEL=google:gemini-2.5-pro
FAST_MODEL=google:gemini-2.0-flash

# Provider API keys (only needed for the provider(s) you use above)
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# GOOGLE_GENERATIVE_AI_API_KEY is read from GOOGLE_API_KEY above
